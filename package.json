{
  "name": "energy-oracle-network",
  "version": "1.0.0",
  "description": "Energy-Aware Oracle Network (EAON) - Multi-Oracle PoC for P2P Energy Trading in Microgrids",
  "main": "index.js",
  "scripts": {
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:dev:3001": "cd frontend && npm run dev -- --port 3001",
    "frontend:build": "cd frontend && npm run build",
    "gas-report": "REPORT_GAS=true ./node_modules/.bin/hardhat test test/unit/EnergyAuction.test.js",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/*.test.js",
    "test:integration": "hardhat test test/integration/*.test.js",
    "test:scenarios": "hardhat test test/scenarios/*.test.js",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "node": "hardhat node",
    "dev": "concurrently \"npm run node\" \"npm run deploy:local\"",
    "hems": "cd mock-hems && npm start",
    "oracle:1": "bash scripts/start-oracle.sh 1",
    "oracle:2": "bash scripts/start-oracle.sh 2",
    "oracle:3": "bash scripts/start-oracle.sh 3",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:restart-oracles": "bash scripts/restart-oracles.sh",
    "verify:oracles": "node scripts/verify-oracle-setup.js",
    "docker:test": "docker-compose -f docker-compose.test.yml up --abort-on-container-exit",
    "k6:setup": "docker-compose down --remove-orphans 2>/dev/null; docker-compose -f docker-compose.k6.yml up -d --remove-orphans && sleep 30",
    "k6:deploy": "bash scripts/deploy-k6.sh",
    "k6:teardown": "docker-compose -f docker-compose.k6.yml down -v --remove-orphans",
    "k6:baseline": "bash scripts/run-k6.sh eaon-baseline.js",
    "k6:stress": "bash scripts/run-k6.sh eaon-stress.js",
    "k6:faults": "bash scripts/run-k6.sh eaon-fault-scenarios.js",
    "k6:crash-fault": "bash scripts/run-k6.sh eaon-crash-fault.js",
    "k6:byzantine-fault": "bash scripts/run-k6.sh eaon-byzantine-fault.js",
    "k6:scalability-5vus": "bash scripts/run-k6.sh eaon-scalability-5vus.js",
    "k6:scalability-10vus": "bash scripts/run-k6.sh eaon-scalability-10vus.js",
    "k6:scalability-20vus": "bash scripts/run-k6.sh eaon-scalability-20vus.js",
    "k6:all": "npm run k6:baseline; npm run k6:crash-fault; npm run k6:byzantine-fault; npm run k6:scalability-5vus; npm run k6:scalability-10vus; npm run k6:scalability-20vus; npm run k6:stress",
    "k6:baseline:testnet": "bash scripts/run-k6.sh eaon-baseline.js --env NETWORK=sepolia",
    "k6:crash-fault:testnet": "bash scripts/run-k6.sh eaon-crash-fault.js --env NETWORK=sepolia",
    "k6:byzantine-fault:testnet": "bash scripts/run-k6.sh eaon-byzantine-fault.js --env NETWORK=sepolia",
    "k6:scalability-5vus:testnet": "bash scripts/run-k6.sh eaon-scalability-5vus.js --env NETWORK=sepolia",
    "k6:scalability-10vus:testnet": "bash scripts/run-k6.sh eaon-scalability-10vus.js --env NETWORK=sepolia",
    "k6:scalability-20vus:testnet": "bash scripts/run-k6.sh eaon-scalability-20vus.js --env NETWORK=sepolia",
    "k6:stress:testnet": "bash scripts/run-k6.sh eaon-stress.js --env NETWORK=sepolia",
    "k6:all:testnet": "npm run k6:baseline:testnet; npm run k6:crash-fault:testnet; npm run k6:byzantine-fault:testnet; npm run k6:scalability-5vus:testnet; npm run k6:scalability-10vus:testnet; npm run k6:scalability-20vus:testnet; npm run k6:stress:testnet",
    "testnet:deploy": "npx hardhat run scripts/testnet/deploy-sepolia.js --network sepolia",
    "testnet:verify": "npx hardhat run scripts/testnet/verify-contracts.js --network sepolia",
    "testnet:test": "node scripts/testnet/performance-test.js",
    "analysis:table": "python3 scripts/analysis/generate-latex-table.py results/local/k6/baseline-results.json",
    "analysis:consolidate": "node scripts/analysis/consolidate-metrics.js",
    "test:full": "bash scripts/run-all-tests.sh",
    "perf:local": "npm run k6:setup && npm run k6:all && npm run k6:teardown",
    "perf:testnet": "npm run testnet:deploy && npm run testnet:test",
    "clean": "hardhat clean && rm -rf cache artifacts",
    "cypress": "cypress",
    "lint": "eslint . --ext .js,.sol",
    "format": "prettier --write .",
    "check-setup": "node scripts/check-setup.js",
    "setup": "npm install && cd oracle-nodes && npm install && cd ../mock-hems && npm install",
    "report": "node scripts/generate-report.js",
    "cypress:open": "docker-compose up -d; docker-compose stop frontend 2>/dev/null; npx wait-on tcp:localhost:8545 tcp:localhost:3000 tcp:localhost:4001 tcp:localhost:4002 tcp:localhost:4003 -t 120000 --delay 5000; start-server-and-test frontend:dev http://localhost:3001 \"cypress run --headed --browser electron\"",
    "cypress:run": "cypress run --browser electron",
    "cypress:report": "cypress run --browser electron --reporter cypress-mochawesome-reporter",
    "cypress:e2e": "cypress run --headed --browser electron --spec 'cypress/e2e/*.cy.ts'",
    "test:e2e": "docker-compose down --remove-orphans; fuser -k 3001/tcp 2>/dev/null || true; sleep 2; docker-compose up -d hardhat-node deployer mock-hems oracle-node-1 oracle-node-2 oracle-node-3; npx wait-on tcp:localhost:8545 tcp:localhost:3000 tcp:localhost:4001 tcp:localhost:4002 tcp:localhost:4003 -t 120000 --delay 5000; start-server-and-test frontend:dev:3001 http://localhost:3001 cypress:report"
  },
  "keywords": [
    "blockchain",
    "oracle",
    "energy-trading",
    "microgrids",
    "p2p",
    "ethereum",
    "hardhat"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "chai": "^4.3.0",
    "concurrently": "^8.2.0",
    "cypress": "^13.17.0",
    "cypress-mochawesome-reporter": "^4.0.2",
    "eslint": "^8.50.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "mochawesome": "^7.1.4",
    "prettier": "^3.0.0",
    "shadcn": "^4.1.2",
    "solidity-coverage": "^0.8.5",
    "start-server-and-test": "^2.1.5",
    "typechain": "^8.3.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.0",
    "ethers": "^6.9.0"
  }
}
